# External API keys
VTOL_OPENAI_API_KEY=

# Service connection (dev)
# VTOL_DB_PATH=postgresql+psycopg://owlpguser:owlpgpassword@localhost:5432/jamaibase_owl
# VTOL_OPENTELEMETRY_HOST=localhost
# VTOL_OPENTELEMETRY_PORT=4317
# VTOL_REDIS_HOST=localhost
# VTOL_REDIS_PORT=6379
# Optional: ResponseStore hot cache (Redis). Disabled by default.
# VTOL_RESPONSE_STORE_CACHE=0              # 0|1
# VTOL_RESPONSE_STORE_CACHE_TTL_SECONDS=3600
# VTOL_VICTORIA_METRICS_HOST=localhost
# VTOL_VICTORIA_LOGS_HOST=localhost
# VTOL_LLM_API_BASE=http://localhost:6970/v1
#
# Tools
# VTOL_CODE_INTERPRETER_MODE=spawn          # spawn | external | disabled
# VTOL_CODE_INTERPRETER_PORT=5970
# VTOL_CODE_INTERPRETER_WORKERS=0
# VTOL_PYODIDE_CACHE_DIR=~/.cache/vllm-responses/pyodide
# VTOL_CODE_INTERPRETER_DEV_BUN_FALLBACK=0  # 0|1 (dev-only; allows bun src fallback when no binary exists)

# Configuration
VTOL_PORT=6969
VTOL_WORKERS=3
PB_MAX_CLIENT_CONN=500
PB_MAX_CLIENT_CONN=80
PG_MAX_CONNECTIONS=100
